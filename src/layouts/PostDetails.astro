---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import type { SortedBlogPost } from "@/utils/getSortedPosts";
import { getPostPath } from "@/utils/getPostPath";
import { resolveOgImage } from "@/utils/ogImage";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import "katex/dist/katex.min.css";

type Props = {
  post: SortedBlogPost;
  posts: SortedBlogPost[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

const { Content, headings } = await render(post);
const tocHeadings = headings
  .filter(
    heading => heading.depth === 2 || heading.depth === 3 || heading.depth === 4
  )
  .slice(0, 12);
const showToc = tocHeadings.length >= 3;

const ogImage = resolveOgImage(initOgImage, Astro.url.origin);

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

const allPosts = posts.map(postEntry => ({
  id: postEntry.id,
  title: postEntry.data.title,
  href: getPostPath(postEntry),
}));

const currentPostIndex = allPosts.findIndex(entry => entry.id === post.id);

const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton layoutClass="post-detail-layout" label="All Posts" />
  <main
    id="main-content"
    class:list={["post-detail-layout pb-12", { "mt-8": !SITE.showBackButton }]}
  >
    <div class="post-detail-grid">
      <div class="post-content-column">
        <h1
          transition:name={slugifyStr(title.replaceAll(".", "-"))}
          class="post-title inline-block text-2xl leading-tight font-semibold sm:text-3xl"
        >
          {title}
        </h1>
        <div class="post-meta my-3 flex flex-wrap items-center gap-2">
          <Datetime
            {pubDatetime}
            {modDatetime}
            size="lg"
            showBothDates={true}
          />
        </div>
        <hr class="post-header-rule sketch-rule" />
        <article id="article" class="app-prose reading-column mt-8">
          {
            showToc && (
              <nav
                aria-label="On this page"
                class="sketch-box sketch-border sketch-border-thin toc-panel post-toc-inline not-prose mb-8 px-5 py-5"
              >
                <ol class="space-y-2 text-sm leading-6">
                  {tocHeadings.map(heading => (
                    <li>
                      <a
                        href={`#${heading.slug}`}
                        class:list={[
                          "toc-link ink-link text-foreground/80 hover:text-foreground",
                          heading.depth === 3 && "level-3",
                          heading.depth === 4 && "level-4",
                        ]}
                        data-toc-link
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            )
          }
          <Content />
        </article>

        <hr class="sketch-rule my-8" />

        <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
          {
            tags.map(tag => (
              <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
            ))
          }
        </ul>

        <BackToTopButton />

        <ShareLinks />

        <hr class="sketch-rule my-6" />

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          {
            prevPost && (
              <a
                href={prevPost.href}
                class="flex w-full gap-1 hover:opacity-75"
              >
                <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
                <div>
                  <span class="notebook-kicker">Previous Post</span>
                  <div class="ink-link content-title mt-1 text-sm">
                    {prevPost.title}
                  </div>
                </div>
              </a>
            )
          }
          {
            nextPost && (
              <a
                href={nextPost.href}
                class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
              >
                <div>
                  <span class="notebook-kicker">Next Post</span>
                  <div class="ink-link content-title mt-1 text-sm">
                    {nextPost.title}
                  </div>
                </div>
                <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
              </a>
            )
          }
        </div>
      </div>

      {
        showToc && (
          <>
            <div class="post-toc-divider" aria-hidden="true" />
            <nav
              aria-label="On this page"
              class="toc-panel post-toc-aside px-4 py-4"
            >
              <ol class="space-y-2 text-sm leading-6">
                {tocHeadings.map(heading => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      class:list={[
                        "toc-link ink-link text-foreground/75 hover:text-foreground",
                        heading.depth === 3 && "level-3",
                        heading.depth === 4 && "level-4",
                      ]}
                      data-toc-link
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { setupPostDetailsPage } from "@/scripts/postDetails.js";

  type PostDetailsWindow = Window & {
    __postDetailsLifecycleCleanup?: () => void;
  };

  (window as PostDetailsWindow).__postDetailsLifecycleCleanup?.();
  document.addEventListener("astro:page-load", setupPostDetailsPage);
  document.addEventListener("astro:after-swap", setupPostDetailsPage);
  (window as PostDetailsWindow).__postDetailsLifecycleCleanup = () => {
    document.removeEventListener("astro:page-load", setupPostDetailsPage);
    document.removeEventListener("astro:after-swap", setupPostDetailsPage);
  };
  setupPostDetailsPage();
</script>
