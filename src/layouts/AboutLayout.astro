---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <div class="page-heading mb-8 inline-flex max-w-full flex-col">
        <h1 class="text-3xl font-semibold sm:text-4xl">
          {frontmatter.title}
        </h1>
        <div class="sketch-divider mt-3 w-full" aria-hidden="true"></div>
      </div>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
