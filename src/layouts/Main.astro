---
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

type StringTitle = { pageTitle: string };
type ArrayTitle = { pageTitle: [string, string]; titleTransition: string };

type Props = (StringTitle | ArrayTitle) & { pageDesc?: string };

const { props } = Astro;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<Breadcrumb />
<main data-backUrl={backUrl} id="main-content" class="app-layout pb-4">
  <div
    class:list={[
      "page-heading inline-flex max-w-full flex-col",
      { "mb-8": !props.pageDesc },
    ]}
  >
    {
      "titleTransition" in props ? (
        <h1 class="text-3xl font-semibold sm:text-4xl">
          {props.pageTitle[0]}
          <span transition:name={props.titleTransition}>
            {props.pageTitle[1]}
          </span>
        </h1>
      ) : (
        <h1 class="text-3xl font-semibold sm:text-4xl">{props.pageTitle}</h1>
      )
    }
    <div class="sketch-divider mt-3 w-full" aria-hidden="true"></div>
  </div>
  {props.pageDesc && <p class="mt-3 mb-8 text-graphite">{props.pageDesc}</p>}
  <slot />
</main>

<script>
  function storeBackUrl() {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  }

  (
    window as Window & { __mainBackUrlCleanup?: () => void }
  ).__mainBackUrlCleanup?.();
  document.addEventListener("astro:page-load", storeBackUrl);
  (
    window as Window & { __mainBackUrlCleanup?: () => void }
  ).__mainBackUrlCleanup = () => {
    document.removeEventListener("astro:page-load", storeBackUrl);
  };
  storeBackUrl();
</script>
