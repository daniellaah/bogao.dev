---
import IconSearch from "@/assets/icons/IconSearch.svg";
import searchKinds from "@/data/search-kinds.json";
import { formatSearchInputPlaceholder } from "@/utils/search";

const searchInputPlaceholder = formatSearchInputPlaceholder(
  searchKinds[0].scope
);
---

<div
  id="command-palette"
  class="command-palette hidden"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="command-palette-title"
  hidden
>
  <button
    type="button"
    class="command-palette__backdrop"
    data-command-close
    aria-label="Close search"
    tabindex="-1"
  >
  </button>
  <div
    class="command-palette__panel sketch-box sketch-border"
    role="document"
    style="--command-top: 0px; --command-left: 0px; --command-width: min(42rem, calc(100vw - 2rem)); --command-collapsed-scale: 0.1;"
  >
    <div class="command-palette__intro flex items-center justify-between gap-4">
      <div>
        <p class="notebook-kicker">Command search</p>
        <h2 id="command-palette-title" class="mt-1 text-xl font-semibold">
          Search anything
        </h2>
      </div>
      <button
        type="button"
        class="command-palette__close sketch-chip px-2 py-1 font-code text-xs"
        data-command-close
      >
        Esc
      </button>
    </div>

    <div class="command-palette__input-wrap">
      <label class="sr-only" for="command-palette-input">Search</label>
      <IconSearch class="command-palette__icon" aria-hidden="true" />
      <input
        id="command-palette-input"
        type="search"
        placeholder={searchInputPlaceholder}
        autocomplete="off"
        aria-busy="false"
        aria-controls="command-palette-results"
        aria-describedby="command-palette-status"
        class="command-palette__input"
      />
      <span
        id="command-palette-thinking"
        class="thinking-dots"
        aria-hidden="true"
      >
        <span></span>
        <span></span>
        <span></span>
      </span>
      <button
        type="button"
        class="command-palette__inline-close"
        data-command-close
        aria-label="Close search"
      >
        <span aria-hidden="true">×</span>
      </button>
    </div>

    <div
      id="command-palette-results-panel"
      class="command-palette__results-panel"
      aria-hidden="true"
      data-empty
    >
      <p
        id="command-palette-status"
        class="command-palette__status font-code text-xs text-graphite"
        role="status"
        aria-live="polite"
        aria-atomic="true"
      >
      </p>
      <ul
        id="command-palette-results"
        class="command-palette__results-list"
        role="list"
      >
      </ul>
    </div>
  </div>
</div>

<script>
  import {
    cleanupCommandPaletteBindings,
    setupCommandPalettePage,
  } from "@/scripts/commandPalette";

  type CommandWindow = Window & {
    __commandPaletteLifecycleCleanup?: () => void;
  };

  (window as CommandWindow).__commandPaletteLifecycleCleanup?.();
  document.addEventListener("astro:page-load", setupCommandPalettePage);
  (window as CommandWindow).__commandPaletteLifecycleCleanup = () => {
    document.removeEventListener("astro:page-load", setupCommandPalettePage);
    cleanupCommandPaletteBindings();
  };
  setupCommandPalettePage();
</script>
