---
import CompactPostRow from "@/components/CompactPostRow.astro";
import type { SortedBlogPost } from "@/utils/getSortedPosts";

type Props = {
  posts: SortedBlogPost[];
  filterable?: boolean;
};

const { posts, filterable = false } = Astro.props;
---

{
  posts.length > 0 ? (
    <ul class="ledger-list--subtle mt-6">
      {posts.map(post => (
        <CompactPostRow {post} {filterable} />
      ))}
    </ul>
  ) : (
    <div class="sketch-box sketch-border px-5 py-8">
      <p class="text-lg font-medium">No posts here yet.</p>
      <p class="mt-2 text-sm leading-7 opacity-75">
        This filtered view is ready, but there are no published articles here
        yet.
      </p>
    </div>
  )
}
