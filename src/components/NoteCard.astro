---
import type { CollectionEntry } from "astro:content";
import dayjs from "@/utils/dayjs";
import { getNotePath } from "@/utils/getNotePath";
import { getPublicImageDimensions } from "@/utils/imageDimensions";

type Props = CollectionEntry<"notes">;

const { id, slug, data } = Astro.props;
const { title, description, noteDate, location, photos } = data;
const href = getNotePath(id, slug);
const photoSrc = photos[0];
const photoDimensions = getPublicImageDimensions(photoSrc);
const heading = title ?? dayjs.utc(noteDate).format("MMM D, YYYY");
---

<article
  class="sketch-list-row grid gap-5 py-7 md:grid-cols-[7rem_minmax(0,1fr)]"
>
  <div class="font-code text-sm tracking-[0.12em] text-graphite uppercase">
    <p class="text-2xl font-semibold text-foreground">
      {dayjs.utc(noteDate).format("DD")}
    </p>
    <p class="mt-1">{dayjs.utc(noteDate).format("MMM YYYY")}</p>
  </div>

  <a href={href} class="group hand-underline-trigger block">
    {location && <div class="notebook-kicker">{location}</div>}

    <h2 class="mt-3 text-xl font-semibold">
      <span class="hand-underline">{heading}</span>
    </h2>
    <p class="mt-3 leading-7 text-graphite">{description}</p>

    {
      photoSrc && (
        <div class="mt-4 overflow-hidden border border-border">
          <img
            src={photoSrc}
            alt={heading}
            width={photoDimensions?.width}
            height={photoDimensions?.height}
            class="h-52 w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      )
    }
  </a>
</article>
