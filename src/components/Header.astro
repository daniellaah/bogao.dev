---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconBox from "@/assets/icons/IconBox.svg";
import IconFileText from "@/assets/icons/IconFileText.svg";
import IconNotebook from "@/assets/icons/IconNotebook.svg";
import IconTag from "@/assets/icons/IconTag.svg";
import IconUserCircle from "@/assets/icons/IconUserCircle.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const navItems = [
  { href: "/posts", label: "Posts", Icon: IconFileText },
  { href: "/projects", label: "Projects", Icon: IconBox },
  { href: "/notes", label: "Notes", Icon: IconNotebook },
  { href: "/tags", label: "Tags", Icon: IconTag },
  { href: "/about", label: "About", Icon: IconUserCircle },
  ...(SITE.showArchives
    ? [{ href: "/archives", label: "Archives", Icon: IconArchive }]
    : []),
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-foreground transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="site-header-layout flex flex-col items-center justify-between lg:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "relative w-full bg-background",
      "flex items-center justify-between",
    ]}
  >
    <a
      href="/"
      class="site-brand site-wordmark absolute py-1 text-xl leading-none font-semibold whitespace-nowrap lg:static lg:my-auto lg:text-2xl"
    >
      <span class="site-avatar" aria-hidden="true">
        <img
          src="/images/site/avatar.svg"
          alt=""
          class="site-avatar__image site-avatar__image--light"
          width="32"
          height="32"
        />
        <img
          src="/images/site/avatar-dark.svg"
          alt=""
          class="site-avatar__image site-avatar__image--dark"
          width="32"
          height="32"
        />
      </span>
      <span>{SITE.title}</span>
    </a>
    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center lg:ms-2 lg:flex-row lg:justify-end lg:space-x-2 lg:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline min-h-11 min-w-11 self-end p-2 lg:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-full max-w-xs grid-cols-2 place-content-center gap-1",
          "sketch-edge-y sketch-mobile-menu py-3 lg:py-0",
          "[&>li>a]:flex [&>li>a]:min-h-11 [&>li>a]:items-center [&>li>a]:justify-center [&>li>a]:px-3 [&>li>a]:py-2 [&>li>a]:text-center [&>li>a]:text-base [&>li>a]:font-medium lg:[&>li>a]:min-h-0 lg:[&>li>a]:px-2 lg:[&>li>a]:py-1 lg:[&>li>a]:text-sm",
          "hidden",
          "lg:mt-0 lg:flex lg:w-auto lg:max-w-none lg:gap-x-2 lg:gap-y-0",
        ]}
      >
        {
          navItems.map(({ href, label, Icon }) => {
            const active = isActive(href);

            return (
              <li>
                <a
                  href={href}
                  data-nav-item={label}
                  class="hand-underline-trigger gap-1.5"
                  aria-current={active ? "page" : undefined}
                >
                  <Icon
                    class:list={[
                      "nav-link-icon",
                      { "nav-link-icon--active": active },
                    ]}
                  />
                  <span
                    class:list={["hand-underline", { "active-nav": active }]}
                  >
                    {label}
                  </span>
                </a>
              </li>
            );
          })
        }

        <li
          class="col-span-2 mt-2 grid grid-cols-2 gap-2 border-t border-border pt-2 lg:mt-0 lg:flex lg:items-center lg:gap-1 lg:border-0 lg:pt-0"
        >
          <LinkButton
            href="/search"
            data-command-open
            class="search-nav-link hand-underline-trigger flex min-h-11 items-center justify-center px-2 py-2 lg:min-h-0 lg:p-1"
            title="Search"
            aria-label="Search. Press Command K to open quick search."
            aria-current={isActive("/search") ? "page" : undefined}
            disableHoverOpacity
          >
            <span class="search-nav-mark" aria-hidden="true">
              <IconSearch class="search-nav-icon size-5 lg:size-6" />
            </span>
            <span
              class:list={[
                "hand-underline ms-1 lg:sr-only",
                { "active-nav": isActive("/search") },
              ]}>Search</span
            >
          </LinkButton>

          <button
            id="theme-btn"
            type="button"
            class="focus-outline flex min-h-11 items-center justify-center px-2 py-2 lg:min-h-0 lg:p-1"
            aria-label="Switch to dark mode"
            title="Switch to dark mode"
          >
            <span class="relative block size-5 lg:size-6" aria-hidden="true">
              <IconMoon
                class="theme-icon theme-icon--moon absolute inset-0 size-full"
              />
              <IconSunHigh
                class="theme-icon theme-icon--sun absolute inset-0 size-full"
              />
            </span>
            <span data-theme-label class="ms-1 lg:sr-only">Dark</span>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  import { setupHeaderNav } from "@/scripts/headerNav";

  (
    window as Window & { __headerNavCleanup?: () => void }
  ).__headerNavCleanup?.();
  document.addEventListener("astro:after-swap", setupHeaderNav);
  (window as Window & { __headerNavCleanup?: () => void }).__headerNavCleanup =
    () => {
      document.removeEventListener("astro:after-swap", setupHeaderNav);
    };
  setupHeaderNav();
</script>
