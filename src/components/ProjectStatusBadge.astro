---
type Props = {
  status: "active" | "shipping" | "archived" | "lab";
};

const { status } = Astro.props;

const labelMap = {
  active: "Active",
  shipping: "Shipping",
  archived: "Archived",
  lab: "Lab",
} as const;

const styleMap = {
  active: "border-solid",
  shipping: "sketch-chip--filled",
  archived: "border-dashed text-graphite",
  lab: "border-dotted",
} as const;
---

<span
  class:list={[
    "sketch-chip inline-flex min-h-0 items-center px-2.5 py-1 font-code text-[11px] font-semibold tracking-[0.16em] uppercase",
    styleMap[status],
  ]}
>
  {labelMap[status]}
</span>
