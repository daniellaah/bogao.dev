---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

type Props = {
  layoutClass?: string;
  label?: string;
};

const { layoutClass = "app-layout", label = "Go back" } = Astro.props;
---

{
  SITE.showBackButton && (
    <div class:list={[layoutClass, "flex items-center justify-start"]}>
      <LinkButton
        id="back-button"
        href="/"
        class="focus-outline -ms-2 mt-8 mb-2 hover:text-foreground/75"
      >
        <IconChevronLeft class="inline-block size-6 rtl:rotate-180" />
        <span>{label}</span>
      </LinkButton>
    </div>
  )
}

<script>
  import { updateBackButtonUrl } from "@/scripts/backNavigation";

  (
    window as Window & { __backButtonCleanup?: () => void }
  ).__backButtonCleanup?.();
  document.addEventListener("astro:page-load", updateBackButtonUrl);
  (
    window as Window & { __backButtonCleanup?: () => void }
  ).__backButtonCleanup = () => {
    document.removeEventListener("astro:page-load", updateBackButtonUrl);
  };
  updateBackButtonUrl();
</script>
