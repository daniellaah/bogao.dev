---
import type { CollectionEntry } from "astro:content";
import ProjectStatusBadge from "./ProjectStatusBadge.astro";
import { getProjectPath } from "@/utils/getProjectPath";

type Props = CollectionEntry<"projects"> & {
  compact?: boolean;
};

const { id, data, compact = false } = Astro.props;
const { title, description, status, stack, year } = data;
const href = getProjectPath(id);
const visibleStack = compact ? stack.slice(0, 3) : stack.slice(0, 4);
---

<article
  class:list={[
    "sketch-list-row group py-7 transition duration-200",
    { "py-5": compact },
  ]}
>
  <div>
    <div class="flex items-baseline gap-4">
      <h2 class="min-w-0 text-2xl font-semibold">
        <a href={href} class="hand-underline">
          {title}
        </a>
      </h2>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <ProjectStatusBadge status={status} />
      {year && <span class="font-code text-xs text-graphite">{year}</span>}
      {
        visibleStack.length > 0 && (
          <span
            class="min-w-0 truncate text-sm text-graphite"
            title={visibleStack.join(" · ")}
          >
            {visibleStack.join(" · ")}
          </span>
        )
      }
    </div>

    <div>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-graphite">
        {description}
      </p>
    </div>
  </div>
</article>
