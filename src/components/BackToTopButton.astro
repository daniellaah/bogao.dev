---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconArrowNarrowUp from "@/assets/icons/IconArrowNarrowUp.svg";
---

<div
  id="btt-btn-container"
  class:list={[
    "fixed end-4 bottom-8 z-50",
    "md:sticky md:end-auto md:float-end md:me-1",
    "translate-y-14 opacity-0 transition duration-500",
  ]}
>
  <button
    data-button="back-to-top"
    class:list={[
      "sketch-chip group relative size-12 bg-background px-2 py-1",
      "md:h-8 md:w-fit",
    ]}
  >
    <IconChevronLeft class="inline-block rotate-90 md:hidden" />
    <span class="sr-only font-code text-xs md:not-sr-only">
      <IconArrowNarrowUp class="inline-block size-4" />
      Back To Top
    </span>
  </button>
</div>

<script>
  import { setupBackToTopButton } from "@/scripts/backToTop";

  type BackToTopWindow = Window & {
    __backToTopCleanup?: () => void;
    __backToTopLifecycleCleanup?: () => void;
  };

  (window as BackToTopWindow).__backToTopLifecycleCleanup?.();
  document.addEventListener("astro:page-load", setupBackToTopButton);
  document.addEventListener("astro:after-swap", setupBackToTopButton);
  (window as BackToTopWindow).__backToTopLifecycleCleanup = () => {
    document.removeEventListener("astro:page-load", setupBackToTopButton);
    document.removeEventListener("astro:after-swap", setupBackToTopButton);
    (window as BackToTopWindow).__backToTopCleanup?.();
  };
  setupBackToTopButton();
</script>
