---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import { SITE } from "@/config";
import { slugifyStr } from "@/utils/slugify";

type Props = {
  posts: CollectionEntry<"blog">[];
};

const { posts } = Astro.props;

dayjs.extend(utc);

const years = Array.from(
  new Set(posts.map(post => dayjs.utc(post.data.pubDatetime).format("YYYY")))
).sort((a, b) => Number(b) - Number(a));

const availableTags = new Map(
  posts.flatMap(post =>
    post.data.tags.map(tag => [slugifyStr(tag), tag] as const)
  )
);

const tags = SITE.postPopularFilterTags.flatMap(configuredTag => {
  const slug = slugifyStr(configuredTag);
  const tagName = availableTags.get(slug);
  return tagName ? [{ slug, tagName }] : [];
});

const filterButtonClass =
  "ink-toggle-button sketch-chip ui-text inline-flex items-center px-2.5 py-1 text-sm font-medium text-graphite";
---

{
  posts.length > 0 && (
    <section
      class="content-controls"
      data-post-filters
      aria-label="Filter posts"
    >
      <div class="content-status">
        <p
          class="content-status__message"
          data-filter-status
          aria-live="polite"
        >
          Showing all {posts.length} posts.
        </p>
      </div>

      <div class="space-y-2">
        <div class="grid gap-2 sm:grid-cols-[3.5rem_minmax(0,1fr)] sm:items-center">
          <span class="notebook-kicker">Year</span>
          <div
            class="ink-toggle flex flex-wrap gap-2"
            data-filter-toggle="year"
          >
            <button
              type="button"
              data-filter-year="all"
              class={filterButtonClass}
              data-active
              aria-pressed="true"
            >
              All
            </button>
            {years.map(year => (
              <button
                type="button"
                data-filter-year={year}
                class={filterButtonClass}
                aria-pressed="false"
              >
                {year}
              </button>
            ))}
          </div>
        </div>

        {tags.length > 0 && (
          <div class="grid gap-2 sm:grid-cols-[3.5rem_minmax(0,1fr)] sm:items-center">
            <span class="notebook-kicker">Tag</span>
            <div class="flex flex-wrap items-center gap-2">
              <div
                class="ink-toggle flex flex-wrap gap-2"
                data-filter-toggle="tag"
              >
                <button
                  type="button"
                  data-filter-tag="all"
                  class={filterButtonClass}
                  data-active
                  aria-pressed="true"
                >
                  All
                </button>
                {tags.map(tag => (
                  <button
                    type="button"
                    data-filter-tag={tag.slug}
                    class={filterButtonClass}
                    aria-pressed="false"
                  >
                    {tag.tagName}
                  </button>
                ))}
              </div>
              <a
                href="/tags/"
                class="sketch-chip ui-text inline-flex min-h-11 items-center px-2.5 py-1 text-sm font-medium text-graphite"
              >
                All Tags
              </a>
            </div>
          </div>
        )}
      </div>
    </section>
  )
}

<script>
  let cleanupPostFiltersInstance = () => {};

  function initPostFilters() {
    const root = document.querySelector<HTMLElement>("[data-post-filters]");
    if (!root || root.dataset.initialized === "true") return;

    cleanupPostFiltersInstance();

    const posts = Array.from(
      document.querySelectorAll<HTMLElement>("[data-post-list-item]")
    );
    const status = root.querySelector<HTMLElement>("[data-filter-status]");
    const yearButtons = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-filter-year]")
    );
    const tagButtons = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-filter-tag]")
    );
    const yearToggle = root.querySelector<HTMLElement>(
      '[data-filter-toggle="year"]'
    );
    const tagToggle = root.querySelector<HTMLElement>(
      '[data-filter-toggle="tag"]'
    );
    const validTags = new Set([
      "all",
      ...tagButtons.map(button => button.dataset.filterTag ?? "all"),
    ]);

    root.dataset.initialized = "true";

    const getParams = () => new URLSearchParams(window.location.search);

    const getFilter = () => {
      const params = getParams();
      const requestedTag = params.get("tag") || "all";
      return {
        year: params.get("year") || "all",
        tag: validTags.has(requestedTag) ? requestedTag : "all",
        invalidTag: !validTags.has(requestedTag),
      };
    };

    const syncToggleIndicator = (
      toggle: HTMLElement | null,
      activeButton: HTMLButtonElement | undefined
    ) => {
      if (!toggle || !activeButton) return;

      toggle.style.setProperty(
        "--sort-indicator-x",
        `${activeButton.offsetLeft}px`
      );
      toggle.style.setProperty(
        "--sort-indicator-y",
        `${activeButton.offsetTop}px`
      );
      toggle.style.setProperty(
        "--sort-indicator-width",
        `${activeButton.offsetWidth}px`
      );
      toggle.style.setProperty(
        "--sort-indicator-height",
        `${activeButton.offsetHeight}px`
      );
    };

    const setActiveButton = (
      buttons: HTMLButtonElement[],
      key: string,
      value: string,
      toggle: HTMLElement | null
    ) => {
      let activeButton: HTMLButtonElement | undefined;

      for (const button of buttons) {
        const isActive = button.dataset[key] === value;
        button.toggleAttribute("data-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
        if (isActive) activeButton = button;
      }

      syncToggleIndicator(toggle, activeButton);
    };

    const updateUrl = (year: string, tag: string) => {
      const params = getParams();
      if (year === "all") params.delete("year");
      else params.set("year", year);
      if (tag === "all") params.delete("tag");
      else params.set("tag", tag);

      const suffix = params.toString();
      history.replaceState(
        history.state,
        "",
        suffix
          ? `${window.location.pathname}?${suffix}`
          : window.location.pathname
      );
    };

    const applyFilter = () => {
      const { year, tag, invalidTag } = getFilter();
      let visibleCount = 0;

      if (invalidTag) updateUrl(year, tag);

      for (const post of posts) {
        const yearMatches = year === "all" || post.dataset.postYear === year;
        const tagMatches =
          tag === "all" ||
          (post.dataset.postTags ?? "").split(" ").includes(tag);
        const visible = yearMatches && tagMatches;

        post.hidden = !visible;
        if (visible) visibleCount += 1;
      }

      setActiveButton(yearButtons, "filterYear", year, yearToggle);
      setActiveButton(tagButtons, "filterTag", tag, tagToggle);

      if (status) {
        status.textContent =
          year === "all" && tag === "all"
            ? `Showing all ${posts.length} posts.`
            : `Showing ${visibleCount} post${visibleCount === 1 ? "" : "s"}.`;
      }
    };

    for (const button of yearButtons) {
      button.addEventListener("click", () => {
        const { tag } = getFilter();
        updateUrl(button.dataset.filterYear ?? "all", tag);
        applyFilter();
      });
    }

    for (const button of tagButtons) {
      button.addEventListener("click", () => {
        const { year } = getFilter();
        updateUrl(year, button.dataset.filterTag ?? "all");
        applyFilter();
      });
    }

    applyFilter();
    window.requestAnimationFrame(() => {
      yearToggle?.setAttribute("data-ink-ready", "true");
      tagToggle?.setAttribute("data-ink-ready", "true");
    });

    let resizeFrame = 0;
    const syncIndicators = () => {
      window.cancelAnimationFrame(resizeFrame);
      resizeFrame = window.requestAnimationFrame(() => {
        const { year, tag } = getFilter();
        setActiveButton(yearButtons, "filterYear", year, yearToggle);
        setActiveButton(tagButtons, "filterTag", tag, tagToggle);
      });
    };

    window.addEventListener("resize", syncIndicators, { passive: true });
    cleanupPostFiltersInstance = () => {
      window.cancelAnimationFrame(resizeFrame);
      window.removeEventListener("resize", syncIndicators);
    };
  }

  (
    window as Window & { __postFiltersCleanup?: () => void }
  ).__postFiltersCleanup?.();
  document.addEventListener("astro:page-load", initPostFilters);
  document.addEventListener("astro:after-swap", initPostFilters);
  (
    window as Window & { __postFiltersCleanup?: () => void }
  ).__postFiltersCleanup = () => {
    document.removeEventListener("astro:page-load", initPostFilters);
    document.removeEventListener("astro:after-swap", initPostFilters);
    cleanupPostFiltersInstance();
  };
</script>
