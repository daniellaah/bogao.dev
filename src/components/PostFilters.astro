---
import dayjs from "@/utils/dayjs";
import { SITE } from "@/config";
import type { SortedBlogPost } from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugifyCore";

type Props = {
  posts: SortedBlogPost[];
};

const { posts } = Astro.props;

const years = Array.from(
  new Set(posts.map(post => dayjs.utc(post.data.pubDatetime).format("YYYY")))
).sort((a, b) => Number(b) - Number(a));

const availableTags = new Map(
  posts.flatMap(post =>
    post.data.tags.map(tag => [slugifyStr(tag), tag] as const)
  )
);

const tags = SITE.postPopularFilterTags.flatMap(configuredTag => {
  const slug = slugifyStr(configuredTag);
  const tagName = availableTags.get(slug);
  return tagName ? [{ slug, tagName }] : [];
});

const filterButtonClass =
  "ink-toggle-button sketch-chip ui-text inline-flex min-h-11 items-center px-3 py-1 text-sm font-medium text-graphite";
---

{
  posts.length > 0 && (
    <section
      class="content-controls"
      data-post-filters
      aria-label="Filter posts"
    >
      <div class="content-status">
        <p
          class="content-status__message"
          data-filter-status
          aria-live="polite"
        >
          Showing all {posts.length} posts.
        </p>
      </div>

      <div class="space-y-2">
        <div class="toggle-control-row">
          <span class="notebook-kicker">Year</span>
          <div
            class="ink-toggle post-filter-toggle flex flex-wrap gap-2"
            data-filter-toggle="year"
            aria-label="Filter posts by year"
          >
            <button
              type="button"
              data-filter-year="all"
              class={filterButtonClass}
              data-active
              aria-pressed="true"
            >
              All
            </button>
            {years.map(year => (
              <button
                type="button"
                data-filter-year={year}
                class={filterButtonClass}
                aria-pressed="false"
              >
                {year}
              </button>
            ))}
          </div>
        </div>

        {tags.length > 0 && (
          <div class="toggle-control-row">
            <span class="notebook-kicker">Tag</span>
            <div class="flex flex-wrap items-center gap-2">
              <div
                class="ink-toggle post-filter-toggle flex flex-wrap gap-2"
                data-filter-toggle="tag"
                aria-label="Filter posts by tag"
              >
                <button
                  type="button"
                  data-filter-tag="all"
                  class={filterButtonClass}
                  data-active
                  aria-pressed="true"
                >
                  All
                </button>
                {tags.map(tag => (
                  <button
                    type="button"
                    data-filter-tag={tag.slug}
                    class={filterButtonClass}
                    aria-pressed="false"
                  >
                    {tag.tagName}
                  </button>
                ))}
              </div>
              <a
                href="/tags/"
                class="sketch-chip ui-text inline-flex min-h-11 items-center px-3 py-1 text-sm font-medium text-graphite"
              >
                All Tags
              </a>
            </div>
          </div>
        )}
      </div>
    </section>
  )
}

<script>
  import {
    cleanupPostFiltersPage,
    setupPostFiltersPage,
  } from "@/scripts/postFilters";

  (
    window as Window & { __postFiltersCleanup?: () => void }
  ).__postFiltersCleanup?.();
  document.addEventListener("astro:page-load", setupPostFiltersPage);
  document.addEventListener("astro:after-swap", setupPostFiltersPage);
  (
    window as Window & { __postFiltersCleanup?: () => void }
  ).__postFiltersCleanup = () => {
    document.removeEventListener("astro:page-load", setupPostFiltersPage);
    document.removeEventListener("astro:after-swap", setupPostFiltersPage);
    cleanupPostFiltersPage();
  };
</script>
