---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CompactPostRow from "@/components/CompactPostRow.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

// Redirect to 404 page if `showArchives` config is false
if (!SITE.showArchives) {
  return Astro.redirect("/404");
}

const posts = getSortedPosts(
  await getCollection("blog", ({ data }) => !data.draft)
);

const months = [
  "January",
  "February",
  "March",
  "April",
  "May",
  "June",
  "July",
  "August",
  "September",
  "October",
  "November",
  "December",
];

const groupedPosts = posts.reduce(
  (groups, post) => {
    const year = String(post.data.pubDatetime.getUTCFullYear());
    const month = String(post.data.pubDatetime.getUTCMonth() + 1).padStart(
      2,
      "0"
    );

    groups[year] ??= {};
    groups[year][month] ??= [];
    groups[year][month].push(post);

    return groups;
  },
  {} as Record<string, Record<string, typeof posts>>
);
---

<Layout title={`Archives | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle="Archives"
    pageDesc="A chronological index of published posts."
  >
    {
      Object.entries(groupedPosts)
        .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
        .map(([year, monthGroups]) => {
          const yearCount = Object.values(monthGroups).flat().length;

          return (
            <section class="sketch-edge-top sketch-section py-8 first:pt-0">
              <h2 class="font-code text-2xl font-semibold">
                {year}
                <sup class="ms-1 text-xs font-medium text-graphite">
                  {yearCount}
                </sup>
              </h2>

              <div class="mt-4 space-y-8">
                {Object.entries(monthGroups)
                  .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
                  .map(([month, monthGroup]) => (
                    <div class="sketch-timeline grid gap-3 ps-4 sm:grid-cols-[8rem_minmax(0,1fr)] sm:ps-0">
                      <div class="notebook-kicker pt-4 sm:pt-0">
                        {months[Number(month) - 1]}
                        <sup class="ms-1 text-xs font-medium">
                          {monthGroup.length}
                        </sup>
                      </div>
                      <ul class="ledger-list--subtle">
                        {monthGroup.map(post => (
                          <CompactPostRow {post} />
                        ))}
                      </ul>
                    </div>
                  ))}
              </div>
            </section>
          );
        })
    }
  </Main>
  <Footer />
</Layout>
