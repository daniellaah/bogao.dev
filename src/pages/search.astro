---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import searchKinds from "@/data/search-kinds.json";
import { SITE } from "@/config";
---

<Layout title={`Search | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Search" pageDesc="Search posts, notes, projects, and tags.">
    <section class="space-y-5">
      <div
        class="sketch-box sketch-border sketch-border-thin search-box relative"
      >
        <label class="sr-only" for="search-input">Search</label>
        <input
          id="search-input"
          type="search"
          placeholder="Search posts, notes, projects, and tags"
          class="search-input w-full border-0 bg-transparent px-5 py-4 pe-24 text-lg outline-hidden placeholder:text-graphite/75"
          autocomplete="off"
        />
        <button
          id="search-clear"
          type="button"
          class="search-clear ink-link absolute top-1/2 right-4 -translate-y-1/2 font-code text-xs text-graphite hover:text-foreground"
        >
          Clear
        </button>
      </div>

      <div
        id="search-kind-filters"
        class="flex flex-wrap gap-2"
        aria-label="Filter search results by type"
      >
        {
          searchKinds.map(kind => (
            <button
              type="button"
              data-search-kind={kind.filter}
              class="sketch-chip ui-text inline-flex items-center px-3 py-1 text-sm font-medium text-graphite transition hover:bg-muted/70 hover:text-foreground"
              aria-pressed={kind.filter === "all" ? "true" : "false"}
              data-active={kind.filter === "all" ? true : undefined}
            >
              {kind.label}
            </button>
          ))
        }
      </div>

      <script
        id="search-kind-data"
        is:inline
        type="application/json"
        set:html={JSON.stringify(searchKinds)}
      />

      <p id="search-status" class="font-code text-xs text-graphite">
        Type a keyword to search across posts, notes, projects, and tags.
      </p>

      <ul id="search-results"></ul>
    </section>
  </Main>
  <Footer />
</Layout>

<script>
  import { setupSearchPage } from "@/scripts/searchPage";

  (
    window as Window & { __searchPageCleanup?: () => void }
  ).__searchPageCleanup?.();
  document.addEventListener("astro:page-load", setupSearchPage);
  document.addEventListener("astro:after-swap", setupSearchPage);
  (
    window as Window & { __searchPageCleanup?: () => void }
  ).__searchPageCleanup = () => {
    document.removeEventListener("astro:page-load", setupSearchPage);
    document.removeEventListener("astro:after-swap", setupSearchPage);
  };
</script>
