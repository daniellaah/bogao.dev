---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import IconLocation from "@/assets/icons/IconLocation.svg";
import getSortedNotes from "@/utils/getSortedNotes";
import { getNotePath } from "@/utils/getNotePath";
import { getPublicImageDimensions } from "@/utils/imageDimensions";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

dayjs.extend(utc);

export const getStaticPaths = (async () => {
  const notes = getSortedNotes(await getCollection("notes"));

  return notes.map(note => ({
    params: { slug: getNotePath(note.id, note.slug).split("/").at(-1) },
    props: { note },
  }));
}) satisfies GetStaticPaths;

const { note } = Astro.props;
const { Content } = await render(note);

const {
  title,
  description,
  noteDate,
  modDatetime,
  location,
  tags,
  photos,
  canonicalURL,
} = note.data;

const heading = title ?? dayjs.utc(noteDate).format("MMM D, YYYY");
const heroImage = photos[0];
const heroImageSrc = heroImage;
const heroImageDimensions = getPublicImageDimensions(heroImageSrc);
const createdDate = dayjs.utc(noteDate).format("YYYY-MM-DD");
const updatedDate = modDatetime
  ? dayjs.utc(modDatetime).format("YYYY-MM-DD")
  : null;
const showUpdatedDate = Boolean(updatedDate && updatedDate !== createdDate);
---

<Layout
  title={`${heading} | Notes | ${SITE.title}`}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={heroImageSrc}
  pubDatetime={noteDate}
  modDatetime={modDatetime}
>
  <Header />
  <BackButton />
  <main id="main-content" class="app-layout pb-12">
    <section
      class:list={[
        "sketch-edge-bottom grid gap-8 pb-8 lg:grid-cols-[8rem_minmax(0,1fr)]",
        showUpdatedDate ? "items-start" : "items-stretch",
      ]}
    >
      <div
        class:list={[
          "sketch-box sketch-border sketch-border-thin p-4",
          showUpdatedDate
            ? "self-start"
            : "flex items-center justify-center lg:h-full",
        ]}
      >
        {
          showUpdatedDate ? (
            <div class="text-left">
              <p class="notebook-kicker text-[0.65rem]">Created</p>
              <p class="mt-1 font-code text-sm font-semibold sm:text-base">
                {createdDate}
              </p>
              <div class="sketch-edge-top mt-3 pt-3">
                <p class="notebook-kicker text-[0.6rem]">Updated</p>
                <p class="mt-1 font-code text-xs font-medium text-graphite sm:text-sm">
                  {updatedDate}
                </p>
              </div>
            </div>
          ) : (
            <div class="text-center">
              <p class="text-3xl font-semibold">
                {dayjs.utc(noteDate).format("DD")}
              </p>
              <p class="notebook-kicker mt-2">
                {dayjs.utc(noteDate).format("MMM YYYY")}
              </p>
            </div>
          )
        }
      </div>

      <div class="flex min-h-full flex-col pt-1">
        {
          location && (
            <p class="notebook-kicker flex items-center gap-2">
              <IconLocation aria-hidden="true" class="size-4 shrink-0" />
              <span aria-hidden="true">•</span>
              <span>{location}</span>
            </p>
          )
        }
        <h1 class="mt-3 text-3xl font-semibold sm:text-4xl">
          {heading}
        </h1>
        {
          tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 md:mt-auto md:pt-4">
              {tags.map(tag => (
                <li>
                  <a
                    href={`/tags/${slugifyStr(tag)}/`}
                    class="hand-underline content-title inline-flex text-sm font-medium tracking-[0.04em]"
                  >
                    #{tag}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </section>

    {
      heroImageSrc && (
        <div class="mt-8 overflow-hidden border border-border">
          <img
            src={heroImageSrc}
            alt={heading}
            width={heroImageDimensions?.width}
            height={heroImageDimensions?.height}
            class="mx-auto block h-auto max-h-[48rem] w-auto max-w-full"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      )
    }

    <article class="app-prose reading-column mt-8">
      <Content />
    </article>

    {
      photos.length > 1 && (
        <section class="sketch-edge-top mt-10 pt-8">
          <h2 class="text-2xl font-semibold">More Photos</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {photos.slice(1).map(photo => {
              const src = photo;
              const dimensions = getPublicImageDimensions(src);
              return (
                <div class="overflow-hidden border border-border">
                  <img
                    src={src}
                    alt={heading}
                    width={dimensions?.width}
                    height={dimensions?.height}
                    class="h-72 w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              );
            })}
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>
