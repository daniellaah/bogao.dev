---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPublishedNotes } from "@/utils/noteVisibility";
import { collectTagStats, type TagStat } from "@/utils/tags";
import { SITE } from "@/config";

const posts = getSortedPosts(await getCollection("blog"));
const notes = getPublishedNotes(await getCollection("notes"));

const tagCollator = new Intl.Collator(undefined, {
  sensitivity: "base",
  numeric: true,
});
const compareTags = (tagA: TagStat, tagB: TagStat) =>
  tagCollator.compare(tagA.tagName, tagB.tagName);
const compareTagsByPopularity = (tagA: TagStat, tagB: TagStat) =>
  tagB.totalCount - tagA.totalCount || compareTags(tagA, tagB);

const tags = collectTagStats([
  ...posts.map(post => ({ tags: post.data.tags, kind: "post" as const })),
  ...notes.map(note => ({ tags: note.data.tags, kind: "note" as const })),
]).sort(compareTags);
const tagsByPopularity = [...tags].sort(compareTagsByPopularity);
---

<Layout title={`Tags | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Tags">
    <section class="space-y-8" data-tags-index data-tags-entering>
      <section>
        <div class="content-controls toggle-panel-rule tags-sort-panel mb-6">
          <div class="content-status">
            <p
              class="content-status__message"
              data-tags-status
              aria-live="polite"
            >
              Showing all {tags.length} topics, sorted by popularity.
            </p>
          </div>

          <div
            class="grid gap-2 sm:grid-cols-[4.5rem_minmax(0,1fr)] sm:items-center"
          >
            <span class="notebook-kicker">Sort By</span>
            <div
              class="ink-toggle tags-sort-toggle flex flex-wrap gap-2"
              aria-label="Sort all tags"
              data-tags-sort-toggle
            >
              <button
                type="button"
                class="ink-toggle-button tags-sort-button sketch-chip ui-text inline-flex min-h-11 items-center px-3 py-1 text-sm font-medium"
                data-tag-sort="popular"
                data-active
                aria-pressed="true"
              >
                Pop
              </button>
              <button
                type="button"
                class="ink-toggle-button tags-sort-button sketch-chip ui-text inline-flex min-h-11 items-center px-3 py-1 text-sm font-medium"
                data-tag-sort="az"
                aria-pressed="false"
              >
                A-Z
              </button>
            </div>
          </div>
        </div>

        <ul class="tags-card-grid" data-tags-card-grid>
          {
            tagsByPopularity.map((tag, index) => (
              <li
                data-tag-card
                data-tag-name={tag.tagName}
                data-total-count={tag.totalCount}
                style={`--tag-enter-delay: ${Math.min(index * 16, 220)}ms;`}
              >
                <a
                  href={`/tags/${tag.slug}/`}
                  class="tags-tag-card sketch-border hand-underline-trigger"
                >
                  <span class="min-w-0">
                    <span class="hand-underline content-title text-lg">
                      #<span transition:name={tag.slug}>{tag.tagName}</span>
                    </span>
                    <span class="mt-1 block font-code text-xs text-graphite">
                      {tag.postCount} posts · {tag.noteCount} notes
                    </span>
                  </span>
                  <span class="tag-count-badge">{tag.totalCount}</span>
                </a>
              </li>
            ))
          }
        </ul>

        {
          tags.length === 0 && (
            <div class="sketch-box sketch-border sketch-border-thin mt-4 px-4 py-5 text-sm text-graphite">
              No tags yet.
            </div>
          )
        }
      </section>
    </section>
  </Main>
  <Footer />
</Layout>

<script>
  import {
    cleanupTagsIndexPage,
    setupTagsIndexPage,
  } from "@/scripts/tagsIndex";

  (
    window as Window & { __tagsIndexCleanup?: () => void }
  ).__tagsIndexCleanup?.();
  document.addEventListener("astro:page-load", setupTagsIndexPage);
  (window as Window & { __tagsIndexCleanup?: () => void }).__tagsIndexCleanup =
    () => {
      document.removeEventListener("astro:page-load", setupTagsIndexPage);
      cleanupTagsIndexPage();
    };
  setupTagsIndexPage();
</script>
