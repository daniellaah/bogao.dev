---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import { getPostPath } from "@/utils/getPostPath";
import { slugifyStr } from "@/utils/slugifyCore";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = getSortedPosts(await getCollection("blog"));
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const taggedPosts = posts
      .filter(post =>
        post.data.tags.some(postTag => slugifyStr(postTag) === tag)
      )
      .map(post => ({
        title: post.data.title,
        href: getPostPath(post),
        date: post.data.pubDatetime,
      }));

    const taggedItems = taggedPosts.sort(
      (a, b) => b.date.getTime() - a.date.getTime()
    );

    return paginate(taggedItems, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
---

<Layout title={`Tag: ${tagName} | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle={[`Tag:`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={`All posts with the tag "${tagName}".`}
  >
    <h1 slot="title" transition:name={tag}>{`Tag:${tag}`}</h1>
    <ul class="mt-6">
      {
        page.data.map(item => (
          <li class="ledger-row last:border-b-0">
            <a
              href={item.href}
              class="hand-underline-trigger grid gap-1 sm:grid-cols-[minmax(0,1fr)_9rem] sm:items-baseline sm:gap-3"
            >
              <span class="min-w-0 text-base leading-none sm:text-[1.15rem] sm:leading-none">
                <span class="hand-underline content-title">{item.title}</span>
              </span>
              <time
                datetime={item.date.toISOString()}
                class="font-code text-xs leading-none tracking-[0.04em] text-graphite sm:text-right"
              >
                {new Intl.DateTimeFormat("en-US", {
                  day: "numeric",
                  month: "short",
                  year: "numeric",
                  timeZone: "UTC",
                }).format(item.date)}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
