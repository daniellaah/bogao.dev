---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import ProjectStatusBadge from "@/components/ProjectStatusBadge.astro";
import getSortedProjects from "@/utils/getSortedProjects";
import { getProjectPath } from "@/utils/getProjectPath";
import { resolveOgImage } from "@/utils/ogImage";
import { SITE } from "@/config";

export const getStaticPaths = (async () => {
  const projects = getSortedProjects(await getCollection("projects"));

  return projects.map(project => ({
    params: { slug: getProjectPath(project.id).split("/").at(-1) },
    props: { project, projects },
  }));
}) satisfies GetStaticPaths;

const { project, projects } = Astro.props;
const { Content } = await render(project);

const {
  title,
  description,
  status,
  stack,
  year,
  demoUrl,
  repoUrl,
  canonicalURL,
} = project.data;
const ogImage = resolveOgImage(project.data.ogImage, Astro.url.origin);

const relatedProjects = projects
  .filter(({ id }) => id !== project.id)
  .slice(0, 3);
---

<Layout
  title={`${title} | Projects | ${SITE.title}`}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
>
  <Header />
  <BackButton />
  <main id="main-content" class="app-layout pb-12">
    <section class="sketch-edge-bottom pb-8">
      <div>
        <div class="flex min-w-0 flex-wrap items-center gap-x-3 gap-y-2">
          <ProjectStatusBadge status={status} />
          {year && <span class="font-code text-xs text-graphite">{year}</span>}
          {
            stack.length > 0 && (
              <span
                class="min-w-0 truncate text-sm text-graphite"
                title={stack.join(" · ")}
              >
                {stack.join(" · ")}
              </span>
            )
          }
        </div>
        <h1 class="mt-5 text-3xl font-semibold sm:text-4xl">
          {title}
        </h1>
        <p class="mt-4 max-w-3xl text-base leading-8 text-graphite">
          {description}
        </p>
        <div class="mt-5 flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium">
          {
            demoUrl && (
              <a href={demoUrl} class="ink-link underline decoration-dashed">
                Demo
              </a>
            )
          }
          {
            repoUrl && (
              <a href={repoUrl} class="ink-link underline decoration-dashed">
                GitHub
              </a>
            )
          }
        </div>
      </div>
    </section>

    <article class="app-prose reading-column mt-8">
      <Content />
    </article>

    {
      relatedProjects.length > 0 && (
        <section class="sketch-edge-top mt-12 pt-8">
          <h2 class="text-2xl font-semibold">More Projects</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {relatedProjects.map(item => (
              <a href={getProjectPath(item.id)} class="ink-link pb-2">
                {item.data.title}
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>
