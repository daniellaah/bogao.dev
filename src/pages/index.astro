---
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostsList from "@/components/PostsList.astro";
import getLatestProjects from "@/utils/getLatestProjects";
import getSortedPosts from "@/utils/getSortedPosts";
import { getProjectPath } from "@/utils/getProjectPath";

dayjs.extend(utc);

const posts = await getCollection("blog");
const projects = await getCollection("projects");
const sortedPosts = getSortedPosts(posts);
const latestPosts = sortedPosts.slice(0, 10);
const latestProjects = getLatestProjects(projects, 4);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-12 pb-10 sm:pt-16">
      <div class="mx-auto max-w-4xl">
        <div class="hero-avatar mx-auto h-36 w-36 sm:h-40 sm:w-40">
          <img
            src="/images/site/avatar.svg"
            alt="Portrait of Bo"
            width="1254"
            height="1254"
            decoding="async"
            class="hero-avatar__image hero-avatar__image--light h-full w-full rounded-full object-cover"
          />
          <img
            src="/images/site/avatar-dark.svg"
            alt="Portrait of Bo"
            width="1254"
            height="1254"
            decoding="async"
            class="hero-avatar__image hero-avatar__image--dark h-full w-full rounded-full object-cover"
          />
        </div>

        <p class="notebook-kicker mt-7 text-center">Personal notebook</p>

        <h1
          class="hero-title mt-2 text-center text-3xl leading-tight font-bold sm:text-4xl"
        >
          BoGao.Dev
        </h1>

        <div
          class="mx-auto mt-5 max-w-2xl space-y-3 text-center text-base leading-7 text-graphite sm:text-[1.15rem] sm:leading-7"
        >
          <p>
            I write about learning, life and love.
            <br />
            I share my thoughts, experiences, and insights.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-8">
      <div>
        <div class="sketch-divider" aria-hidden="true"></div>
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="notebook-kicker">01 / Build log</p>
            <h2 class="mt-1 text-2xl font-semibold sm:text-3xl">
              Latest Projects
            </h2>
          </div>
          <a
            href="/projects/"
            class="ink-link font-code text-xs text-graphite hover:text-foreground"
          >
            View all
          </a>
        </div>

        <ul class="ledger-list--subtle mt-5">
          {
            latestProjects.map(project => (
              <li class="ledger-row last:border-b-0">
                <a
                  href={getProjectPath(project.id)}
                  class="hand-underline-trigger grid gap-1 sm:grid-cols-[minmax(0,1fr)_9rem] sm:items-baseline sm:gap-3"
                >
                  <span class="min-w-0 text-base leading-none sm:text-[1.15rem] sm:leading-none">
                    <span class="hand-underline content-title">
                      {project.data.title}
                    </span>
                  </span>
                  <time class="font-code text-xs leading-none tracking-[0.04em] text-graphite sm:text-right">
                    {project.data.startDate
                      ? dayjs.utc(project.data.startDate).format("D MMM YYYY")
                      : String(project.data.year ?? "")}
                  </time>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="pb-8">
      <div>
        <div class="sketch-divider" aria-hidden="true"></div>
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="notebook-kicker">02 / Field notes</p>
            <h2 class="mt-1 text-2xl font-semibold sm:text-3xl">
              Latest Posts
            </h2>
          </div>
          <a
            href="/posts/"
            class="ink-link font-code text-xs text-graphite hover:text-foreground"
          >
            View all
          </a>
        </div>

        <PostsList posts={latestPosts} />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  type HomeWindow = Window & {
    __homeBackUrlCleanup?: () => void;
    __homeAvatarHoverCleanup?: () => void;
    __homeAvatarLastReplayAt?: number;
  };

  function storeHomeBackUrl() {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  }

  function replayHeroAvatarAnimation() {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout !== "index") return;

    const homeWindow = window as HomeWindow;
    const now = performance.now();
    if (
      homeWindow.__homeAvatarLastReplayAt &&
      now - homeWindow.__homeAvatarLastReplayAt < 300
    ) {
      return;
    }
    homeWindow.__homeAvatarLastReplayAt = now;

    const replayKey = `${Date.now()}-${Math.round(now)}`;
    document
      .querySelectorAll<HTMLImageElement>(".hero-avatar__image")
      .forEach((image, index) => {
        const baseSrc =
          image.dataset.avatarSrc ??
          image.getAttribute("src")?.split("?")[0] ??
          "";
        if (!baseSrc) return;

        image.dataset.avatarSrc = baseSrc;
        image.src = `${baseSrc}?replay=${replayKey}-${index}`;
      });
  }

  function bindHeroAvatarReplay() {
    const homeWindow = window as HomeWindow;
    homeWindow.__homeAvatarHoverCleanup?.();
    homeWindow.__homeAvatarHoverCleanup = undefined;

    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout !== "index") return;

    const avatar = document.querySelector<HTMLElement>(".hero-avatar");
    if (!avatar) return;

    avatar.addEventListener("pointerenter", replayHeroAvatarAnimation);
    homeWindow.__homeAvatarHoverCleanup = () => {
      avatar.removeEventListener("pointerenter", replayHeroAvatarAnimation);
    };
  }

  function initHomePage() {
    storeHomeBackUrl();
    replayHeroAvatarAnimation();
    bindHeroAvatarReplay();
  }

  (window as HomeWindow).__homeBackUrlCleanup?.();
  document.addEventListener("astro:page-load", initHomePage);
  (window as HomeWindow).__homeBackUrlCleanup = () => {
    document.removeEventListener("astro:page-load", initHomePage);
    (window as HomeWindow).__homeAvatarHoverCleanup?.();
    (window as HomeWindow).__homeAvatarHoverCleanup = undefined;
  };
  initHomePage();
</script>
