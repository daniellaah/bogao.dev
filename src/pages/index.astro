---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import NoteCard from "@/components/NoteCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getSortedProjects from "@/utils/getSortedProjects";
import getSortedNotes from "@/utils/getSortedNotes";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");
const projects = await getCollection("projects");
const notes = await getCollection("notes");

const sortedPosts = getSortedPosts(posts);
const sortedProjects = getSortedProjects(projects);
const sortedNotes = getSortedNotes(notes);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const featuredProjects = sortedProjects.slice(0, 3);
const recentNotes = sortedNotes.slice(0, 2);
const focusAreas = [
  {
    title: "ML Notes",
    body: "整理机器学习课程、经典模型和推导过程，把旧笔记沉淀成能反复查阅的内容。",
  },
  {
    title: "LLM Workflow",
    body: "记录 prompt、评测、agent 协作和 AI coding workflow 在真实项目里的有效用法。",
  },
  {
    title: "Experiments",
    body: "把小型 AI 工具、知识整理系统和个人实验做成可持续迭代的项目记录。",
  },
];
const principles = [
  "尽量把概念、公式和实现放在同一篇内容里讲清楚。",
  "优先记录实验结论和失败原因，而不是只贴一个结果。",
  "让文章和项目都能在半年后重新读懂，而不是只服务当下。",
];
---

<Layout lang="zh-CN">
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "grid gap-8 border-b border-border pt-10 pb-8 sm:pt-14",
        "lg:grid-cols-[minmax(0,1.5fr)_minmax(18rem,0.9fr)]",
      ]}
    >
      <div>
        <div class="flex items-center gap-3">
          <h1 class="inline-block text-4xl font-bold sm:text-6xl">
            BoGao.Dev
          </h1>
          <a
            target="_blank"
            href="/rss.xml"
            class="inline-block"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss
              width={20}
              height={20}
              class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
            />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>
        <p class="mt-6 max-w-2xl text-lg leading-8">
          我用这个博客整理机器学习笔记、LLM workflow 和个人实验。
          这里更像一个长期积累判断的研究日志，而不是通用模板站。
        </p>
        <p class="mt-3 max-w-2xl text-base leading-7 opacity-80">
          Focused on models, tooling, and experiments that are worth keeping
          after the first burst of curiosity is gone.
        </p>
        <div class="mt-6 flex flex-wrap gap-x-6 gap-y-3 text-sm font-medium">
          <span>Astro + Vercel</span>
          <span>ML + LLM + Experiments</span>
        </div>
        <div class="mt-7 flex flex-wrap gap-4">
          <LinkButton
            href="/projects/"
            class="rounded-full border border-border px-5 py-2.5 hover:border-accent"
          >
            View Projects
          </LinkButton>
          <LinkButton
            href="/notes/"
            class="rounded-full border border-border px-5 py-2.5 hover:border-accent"
          >
            Open Notes
          </LinkButton>
          <LinkButton
            href="/posts/"
            class="rounded-full border border-border px-5 py-2.5 hover:border-accent"
          >
            Read Posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
          <LinkButton
            href="/about/"
            class="rounded-full border border-border px-5 py-2.5 hover:border-accent"
          >
            About Bo
          </LinkButton>
        </div>
      </div>

      <aside class="rounded-3xl border border-border p-5 sm:p-6">
        <p class="text-sm font-medium tracking-[0.18em] text-accent uppercase">
          Current Focus
        </p>
        <ul class="mt-4 space-y-4 text-sm leading-7">
          <li>
            把早年的机器学习课程笔记重新整理进统一的内容结构里，清掉历史迁移留下的问题。
          </li>
          <li>
            用 notes 和 projects 记录 LLM workflow、小工具和实验中的判断，而不是只留下聊天记录。
          </li>
          <li>
            保持发布链路简单，让博客既能放长文，也能承载短笔记、实验日志和项目页面。
          </li>
        </ul>
        {
          SOCIALS.length > 0 && (
            <div class="mt-5 border-t border-border pt-4">
              <p class="mb-2 text-xs tracking-[0.18em] uppercase opacity-70">
                Find me
              </p>
              <Socials />
            </div>
          )
        }
      </aside>
    </section>

    {
      featuredProjects.length > 0 && (
        <section id="projects" class="border-b border-border py-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <p class="text-sm font-medium tracking-[0.18em] text-accent uppercase">
                Projects
              </p>
              <h2 class="mt-3 text-2xl font-semibold sm:text-3xl">
                Small systems around ML notes, LLM tools, and experimental workflows.
              </h2>
            </div>
            <LinkButton href="/projects/">Browse all projects</LinkButton>
          </div>
          <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {featuredProjects.map(project => <ProjectCard {...project} compact />)}
          </div>
        </section>
      )
    }

    {
      recentNotes.length > 0 && (
        <section id="notes" class="border-b border-border py-10">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <p class="text-sm font-medium tracking-[0.18em] text-accent uppercase">
                Notes
              </p>
            </div>
            <LinkButton href="/notes/">Open all notes</LinkButton>
          </div>
          <div class="mt-6">
            {recentNotes.map(note => <NoteCard {...note} compact />)}
          </div>
        </section>
      )
    }

    <section
      id="focus"
      class="grid gap-4 border-b border-border py-8 sm:grid-cols-3"
    >
      {
        focusAreas.map(item => (
          <article class="rounded-3xl border border-border p-5">
            <h2 class="text-xl font-semibold">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 opacity-80">{item.body}</p>
          </article>
        ))
      }
    </section>

    <section
      id="principles"
      class="grid gap-8 border-b border-border py-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]"
    >
      <div>
        <p class="text-sm font-medium tracking-[0.18em] text-accent uppercase">
          What This Blog Is For
        </p>
        <h2 class="mt-3 text-2xl font-semibold sm:text-3xl">
          A place to keep models, experiments, and working notes in one durable archive.
        </h2>
        <p class="mt-4 max-w-2xl leading-8 opacity-85">
          我希望这里最终沉淀下来的，不只是课程摘要或产品更新，而是自己对模型、工具和工作流的长期理解。
          每篇文章最好都能回答一个具体问题，或者把一次实验真正讲清楚。
        </p>
      </div>
      <div class="rounded-3xl bg-muted/35 p-5">
        <p class="text-sm font-medium tracking-[0.18em] uppercase opacity-80">
          Writing Principles
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-7">
          {principles.map(item => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Latest Writing</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        Browse All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
